---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* Article page uses the global page width and the global H1 scale.
			 * In-article hierarchy is delivered by .prose h2/h3 (global.css).
			 */
			main {
				width: var(--page-width);
				max-width: calc(100% - 2em);
				margin: auto;
				padding: var(--page-padding-y) 1em 0;
			}
			.hero-image {
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.title-block {
				margin: 0 0 var(--section-gap);
				padding-bottom: 1.4rem;
				border-bottom: 1px solid var(--hairline-soft);
			}
			.title-block h1 {
				margin: 0 0 0.6rem;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: var(--text-meta);
				font-family: var(--font-sans-zh);
				font-weight: 500;
			}
			.last-updated-on {
				margin-top: 0.2rem;
				font-size: var(--text-meta);
				color: rgb(var(--gray));
				font-family: var(--font-sans-zh);
			}
			.prose {
				color: rgb(var(--gray-dark));
				font-family: var(--font-serif-zh);
				padding-bottom: var(--page-padding-y);
			}
			.prose :global(.katex-display) {
				margin: 1.7em 0;
				overflow-x: auto;
				overflow-y: hidden;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<header class="title-block">
					<h1>{title}</h1>
					<p class="date">
						<FormattedDate date={pubDate} />
					</p>
					{
						updatedDate && (
							<p class="last-updated-on">
								更新于 <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			const runMermaid = async () => {
				const targets = document.querySelectorAll('pre[data-language="mermaid"] > code');
				if (!targets.length) return;

				for (const code of targets) {
					const parent = code.parentElement;
					if (!parent) continue;
					const container = document.createElement('div');
					container.className = 'mermaid';
					container.textContent = code.textContent ?? '';
					parent.replaceWith(container);
				}

				try {
					const { default: mermaid } = await import('mermaid');
					mermaid.initialize({
						startOnLoad: false,
						theme: 'neutral',
						securityLevel: 'loose',
					});
					mermaid.run({
						querySelector: '.mermaid',
					});
				} catch {
					// If Mermaid fails to load, keep the original code block visible.
				}
			};

			runMermaid();
		</script>
	</body>
</html>
