---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, toInternalPath } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 860px;
			}
			h1 {
				margin-bottom: 0.35em;
			}
			.intro {
				margin-bottom: 2rem;
				color: rgb(var(--gray));
				font-size: 1rem;
			}
			.post-list {
				display: flex;
				flex-direction: column;
				gap: 1.1rem;
			}
			.post-item {
				padding: 1.2rem 1.3rem;
				border: 1px solid rgba(176, 74, 37, 0.2);
				border-radius: 12px;
				background: #fff;
			}
			.post-item a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-item:hover {
				box-shadow: var(--box-shadow);
				transform: translateY(-1px);
				transition: box-shadow 220ms var(--ease-out), transform 220ms var(--ease-out);
			}
			.meta {
				display: flex;
				gap: 0.7rem;
				align-items: center;
				font-size: 0.75rem;
				color: rgb(var(--gray));
				margin-bottom: 0.3rem;
			}
			.title {
				font-size: 1.5rem;
				line-height: 1.35;
				margin-bottom: 0.28rem;
			}
			.desc {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.65;
			}
			.tags {
				margin-top: 0.8rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}
			.tag {
				font-size: 0.75rem;
				padding: 0.12rem 0.5rem;
				border-radius: 999px;
				border: 1px solid rgba(176, 74, 37, 0.35);
				color: var(--accent-dark);
			}
			.count {
				color: rgb(var(--gray));
				font-size: 1rem;
			}
			@media (max-width: 760px) {
				main {
					width: 100%;
				}
				.post-item {
					padding: 1rem;
				}
				.title {
					font-size: 1.25rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>文章</h1>
			<p class="intro">围绕 AI 时代工作流、生产力与生产关系变化的持续写作。</p>
			<p class="count">共 {posts.length} 篇</p>
			<section class="post-list">
					{
						posts.map((post) => (
							<article class="post-item">
								<a href={toInternalPath(`/blog/${post.id}/`)}>
									<div class="meta">
										<FormattedDate date={post.data.pubDate} />
										{post.data.series && <span>· {post.data.series}</span>}
									</div>
									<h3 class="title">{post.data.title}</h3>
									<p class="desc">{post.data.description}</p>
									{
										post.data.tags.length > 0 && (
											<div class="tags">
												{post.data.tags.map((tag) => (
													<span class="tag">#{tag}</span>
												))}
											</div>
										)
									}
								</a>
							</article>
						))
					}
			</section>
		</main>
		<Footer />
	</body>
</html>
