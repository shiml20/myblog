---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, toInternalPath } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const estimateReadingMinutes = (body: string) =>
	Math.max(4, Math.ceil(body.replace(/\s+/g, '').length / 450));

const getPostType = (post: (typeof posts)[number]) =>
	post.data.tags[0] ?? post.data.series ?? 'Essay';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin: 0.4rem 0 0.4rem;
				color: rgb(var(--gray-dark));
				font-family: var(--font-serif-zh);
				font-size: clamp(1rem, 1.6vw, 1.15rem);
				line-height: 1.85;
			}
			.count {
				color: rgb(var(--gray));
				font-size: var(--text-meta);
				font-family: var(--font-sans-zh);
				margin: 0 0 var(--section-gap);
			}
			.post-list {
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-item a {
				text-decoration: none;
				color: inherit;
				display: block;
				padding: 1.05rem 1.1rem;
				border-radius: 18px;
				border: 1px solid var(--hairline);
				background: rgba(255, 250, 246, 0.7);
				box-shadow: 0 12px 28px rgba(79, 43, 24, 0.05);
				transition: transform 240ms var(--ease-out), box-shadow 240ms var(--ease-out), border-color 240ms var(--ease-out);
			}
			.post-item a:hover {
				transform: translateY(-3px);
				border-color: rgba(161, 74, 42, 0.34);
				box-shadow: 0 18px 40px rgba(79, 43, 24, 0.1);
			}
			.post-item h3 {
				margin: 0.25rem 0 0;
				color: rgb(var(--black));
				transition: color 220ms var(--ease-out);
			}
			.post-item a:hover h3 {
				color: var(--accent-dark);
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				align-items: center;
				font-size: var(--text-meta);
				color: rgb(var(--gray));
				font-family: var(--font-sans-zh);
				font-weight: 650;
				line-height: 1.4;
			}
			.desc {
				margin: 0.4rem 0 0;
				color: rgb(var(--gray-dark));
				font-family: var(--font-serif-zh);
				font-size: var(--text-excerpt);
				line-height: 1.65;
			}
			.tags {
				margin-top: 0.55rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
			}
			.tag {
				font-size: var(--text-meta);
				font-family: var(--font-sans-zh);
				padding: 0.1rem 0.5rem;
				border-radius: 999px;
				border: 1px solid rgba(161, 74, 42, 0.28);
				color: var(--accent-dark);
				background: rgba(243, 232, 226, 0.48);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>文章</h1>
			<p class="intro">围绕 AI 时代工作流、生产力与生产关系变化的持续写作。</p>
			<p class="count">共 {posts.length} 篇</p>
			<ul class="post-list">
					{
						posts.map((post) => (
							<li class="post-item">
								<a href={toInternalPath(`/blog/${post.id}/`)} data-astro-prefetch="viewport">
									<div class="meta">
										<span>{getPostType(post)}</span>
										<span>·</span>
										<span>{estimateReadingMinutes(post.body)} min</span>
										<span>·</span>
										<FormattedDate date={post.data.pubDate} />
										{post.data.series && <span>· {post.data.series}</span>}
									</div>
									<h3>{post.data.title}</h3>
									<p class="desc">{post.data.description}</p>
									{
										post.data.tags.length > 0 && (
											<div class="tags">
												{post.data.tags.map((tag) => (
													<span class="tag">#{tag}</span>
												))}
											</div>
										)
									}
								</a>
							</li>
						))
					}
			</ul>
		</main>
		<Footer />
	</body>
</html>
