---
import { SITE_HEADER_MARK, SITE_TITLE, toInternalPath } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="主导航">
		<h2>
			<a
				href={toInternalPath()}
				class="site-logo"
				data-astro-prefetch="viewport"
				title={`${SITE_HEADER_MARK} · ${SITE_TITLE}`}
				lang="en"
				aria-label={`${SITE_HEADER_MARK} · ${SITE_TITLE}，回到首页`}
			>
				<span class="site-logo-wordmark">{SITE_HEADER_MARK}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href={toInternalPath()}>首页</HeaderLink>
			<HeaderLink href={toInternalPath('/blog')}>文章</HeaderLink>
			<HeaderLink href={toInternalPath('/themes')}>主题</HeaderLink>
			<HeaderLink href={toInternalPath('/now')}>Now</HeaderLink>
			<HeaderLink href={toInternalPath('/about')}>关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(248, 243, 238, 0.88);
		border-bottom: 1px solid rgba(161, 74, 42, 0.14);
		position: sticky;
		top: 0;
		backdrop-filter: blur(14px);
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		line-height: 1;
	}

	.site-logo {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 0.45rem 0;
		border-radius: 10px;
	}
	.site-logo-wordmark {
		font-family:
			ui-sans-serif,
			system-ui,
			-apple-system,
			'Segoe UI',
			sans-serif;
		font-size: clamp(0.94rem, 1.15vw, 1.05rem);
		font-weight: 700;
		letter-spacing: 0.04em;
		color: rgb(var(--black));
		line-height: 1.2;
		transition: color 200ms var(--ease-out);
	}
	.site-logo:hover .site-logo-wordmark,
	.site-logo:focus-visible .site-logo-wordmark {
		color: var(--accent-dark);
	}
	.site-logo:focus-visible {
		outline: 2px solid rgba(161, 74, 42, 0.45);
		outline-offset: 3px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(var(--home-width), 100%);
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		flex-wrap: wrap;
	}
	.internal-links a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-family: var(--font-sans-zh);
		font-size: var(--text-meta);
		font-weight: 700;
		transition: border-color 220ms var(--ease-out), color 220ms var(--ease-out);
	}
	.internal-links a:hover {
		color: var(--accent-dark);
	}
	.internal-links a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.65em;
		}
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}
		.internal-links {
			justify-content: center;
		}
	}
</style>
