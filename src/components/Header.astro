---
import { SITE_TITLE } from '../consts';
import { toInternalPath } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="主导航">
		<h2><a href={toInternalPath()}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={toInternalPath()}>首页</HeaderLink>
			<HeaderLink href={toInternalPath('/blog')}>文章</HeaderLink>
			<HeaderLink href={toInternalPath('/themes')}>主题</HeaderLink>
			<HeaderLink href={toInternalPath('/now')}>Now</HeaderLink>
			<HeaderLink href={toInternalPath('/about')}>关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(248, 246, 242, 0.96);
		border-bottom: 1px solid rgba(176, 74, 37, 0.14);
		position: sticky;
		top: 0;
		backdrop-filter: blur(6px);
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(960px, 100%);
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		flex-wrap: wrap;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		transition: border-color 220ms var(--ease-out), color 220ms var(--ease-out);
	}
	nav a:hover {
		color: var(--accent-dark);
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.65em;
		}
		nav {
			flex-wrap: wrap;
			justify-content: center;
		}
		.internal-links {
			justify-content: center;
		}
	}
</style>
